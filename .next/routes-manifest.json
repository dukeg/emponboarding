{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "/emponboarding",
  "redirects": [
    {
      "source": "/emponboarding/",
      "destination": "/emponboarding",
      "basePath": false,
      "internal": true,
      "statusCode": 308,
      "regex": "^/emponboarding/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/404",
      "regex": "^/404(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/404(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/onboarding/checklist",
      "regex": "^/onboarding/checklist(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/onboarding/checklist(?:/)?$"
    },
    {
      "page": "/onboarding/documents",
      "regex": "^/onboarding/documents(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/onboarding/documents(?:/)?$"
    },
    {
      "page": "/onboarding/training",
      "regex": "^/onboarding/training(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/onboarding/training(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc"
  },
  "rewrites": []
}